@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .login-wrap {
        max-width: 420px;
        margin: 4rem auto;
        padding: 0 1.5rem;
    }

    .login-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
    }

    .login-title {
        font-family: 'Syne', sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

        .login-title span {
            color: #ff2222;
        }

    .login-sub {
        font-size: 0.85rem;
        color: #7a7a8c;
        margin-top: 0.4rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
        display: block;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background: #18181f !important;
        border: 1px solid #2e2e3a !important;
        color: #f0f0f5 !important;
        padding: 0.75rem 1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        width: 100%;
        border-radius: 0 !important;
        outline: none;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            border-color: #ff2222 !important;
            box-shadow: none !important;
        }

        .form-control::placeholder {
            color: #7a7a8c;
        }

    .text-danger {
        font-size: 0.78rem;
        color: #ff4d6d !important;
    }

    .btn-login {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.9rem;
        width: 100%;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 0.5rem;
    }

        .btn-login:hover {
            background: #ff4444;
            transform: translateY(-2px);
        }

    .login-footer {
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.85rem;
        color: #7a7a8c;
    }

        .login-footer a {
            color: #ff2222;
            text-decoration: none;
        }

            .login-footer a:hover {
                color: #ff6666;
            }
</style>

<div class="login-wrap">
    <div class="login-header">
        <h1 class="login-title">Log <span>In</span></h1>
        <p class="login-sub">Welcome back to Bob The Driver.</p>
    </div>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label class="form-label" asp-for="Input.UserName"></label>
            <input class="form-control" asp-for="Input.UserName" placeholder="UserName" />
            <span asp-validation-for="Input.UserName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Input.Password"></label>
            <input class="form-control" asp-for="Input.Password" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-login">Log In →</button>
    </form>

    <div class="login-footer">
        <p>Don't have an account? <a asp-page="./Register">Register here</a></p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}