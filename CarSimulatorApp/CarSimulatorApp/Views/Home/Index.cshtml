@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .welcome-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        text-align: center;
        gap: 1.5rem;
    }

    .welcome-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(3rem, 10vw, 7rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1;
        color: #f0f0f5;
        margin: 0;
    }

    .welcome-title span {
        color: #ff2222;
    }

    .welcome-sub {
        font-size: 1.1rem;
        color: #7a7a8c;
        max-width: 500px;
    }

    .welcome-sub a {
        color: #ff2222;
        text-decoration: none;
        border-bottom: 1px solid #ff2222;
    }

    .welcome-sub a:hover {
        color: #ff6666;
        border-color: #ff6666;
    }

    .welcome-btn {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-block;
        margin-top: 1rem;
    }

    .welcome-btn:hover {
        background: #ff4444;
        color: #fff;
        transform: translateY(-2px);
    }
</style>

<div class="welcome-section">
    <h1 class="welcome-title">Bob The <span>Driver</span></h1>
    <p class="welcome-sub">
        Your one-stop shop for car simulator gear. <br/>
        <a asp-controller="Product" asp-action="Index">Browse our products</a> and find your perfect setup.
    </p>
    <a asp-controller="Product" asp-action="Index" class="welcome-btn">Shop Now →</a>
</div>
