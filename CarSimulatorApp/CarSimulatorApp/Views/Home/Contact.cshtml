@{
    ViewData["Title"] = "Contact";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .contact-wrap {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .contact-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
    }

    .contact-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

        .contact-title span {
            color: #ff2222;
        }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .contact-card {
        background: #18181f;
        border: 1px solid #2e2e3a;
        padding: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        transition: border-color 0.25s;
    }

        .contact-card:hover {
            border-color: #ff2222;
        }

    .contact-icon {
        font-size: 1.75rem;
    }

    .contact-info-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
        display: block;
        margin-bottom: 0.25rem;
    }

    .contact-info-value {
        font-size: 0.95rem;
        color: #f0f0f5;
        font-weight: 500;
    }

        .contact-info-value a {
            color: #ff2222;
            text-decoration: none;
        }

    /* Form */
    .contact-form-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #f0f0f5;
        margin-bottom: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
        display: block;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background: #18181f !important;
        border: 1px solid #2e2e3a !important;
        color: #f0f0f5 !important;
        padding: 0.75rem 1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        width: 100%;
        border-radius: 0 !important;
        outline: none;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            border-color: #ff2222 !important;
            box-shadow: none !important;
        }

        .form-control::placeholder {
            color: #7a7a8c;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 140px;
    }

    .btn-send {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.9rem 2.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
        width: 100%;
        margin-top: 0.5rem;
    }

        .btn-send:hover {
            background: #ff4444;
            transform: translateY(-2px);
        }

    @@media (max-width: 650px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="contact-wrap">
    <div class="contact-header">
        <h1 class="contact-title">Get In <span>Touch</span></h1>
    </div>

    <div class="contact-grid">
        <div class="contact-card">
            <span class="contact-icon">📧</span>
            <div>
                <span class="contact-info-label">Email</span>
                <span class="contact-info-value">
                    <a href="mailto:support@bobthedriver.com">support@@bobthedriver.com</a>
                </span>
            </div>
        </div>
        <div class="contact-card">
            <span class="contact-icon">📞</span>
            <div>
                <span class="contact-info-label">Phone</span>
                <span class="contact-info-value">+1 (555) 123-4567</span>
            </div>
        </div>
        <div class="contact-card">
            <span class="contact-icon">📍</span>
            <div>
                <span class="contact-info-label">Address</span>
                <span class="contact-info-value">123 Racing Street, Sofia, Bulgaria</span>
            </div>
        </div>
        <div class="contact-card">
            <span class="contact-icon">🕐</span>
            <div>
                <span class="contact-info-label">Working Hours</span>
                <span class="contact-info-value">Mon–Fri: 9:00 – 18:00</span>
            </div>
        </div>
    </div>

   