@{
    ViewData["Title"] = "Privacy Policy";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .privacy-wrap {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .privacy-title {
        font-family: 'Syne', sans-serif;
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin-bottom: 0.25rem;
    }

        .privacy-title span {
            color: #ff2222;
        }

    .privacy-date {
        font-size: 0.8rem;
        color: #7a7a8c;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
    }

    .privacy-section {
        margin-bottom: 2.5rem;
    }

        .privacy-section h2 {
            font-family: 'Syne', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #ff2222;
            margin-bottom: 0.75rem;
        }

        .privacy-section p {
            color: #a0a0b0;
            line-height: 1.8;
            font-size: 0.95rem;
        }
</style>

<div class="privacy-wrap">
    <h1 class="privacy-title">Privacy <span>Policy</span></h1>
    <p class="privacy-date">Last updated: April 2026</p>

    <div class="privacy-section">
        <h2>1. Information We Collect</h2>
        <p>When you register on Bob The Driver, we collect your name, email address, and order history. We do not collect any payment information directly — all transactions are handled securely by third-party providers.</p>
    </div>

    <div class="privacy-section">
        <h2>2. How We Use Your Information</h2>
        <p>Your information is used solely to process orders, manage your account, and improve your experience on our platform. We do not sell or share your personal data with any third parties for marketing purposes.</p>
    </div>

    <div class="privacy-section">
        <h2>3. Cookies</h2>
        <p>Bob The Driver uses cookies to keep you logged in and remember your preferences such as favourited products. You can disable cookies in your browser settings, though some features may not function correctly without them.</p>
    </div>

    <div class="privacy-section">
        <h2>4. Data Security</h2>
        <p>We take reasonable measures to protect your personal information from unauthorized access. All passwords are encrypted and we follow industry-standard security practices to keep your data safe.</p>
    </div>

    <div class="privacy-section">
        <h2>5. Your Rights</h2>
        <p>You have the right to access, update, or delete your personal information at any time. To request changes to your data, please contact us directly through the platform.</p>
    </div>

    <div class="privacy-section">
        <h2>6. Contact</h2>
        <p>If you have any questions about this privacy policy, feel free to reach out to us at <span style="color:#ff2222;">support@bobthedriver.com</span>.</p>
    </div>
</div>
