@{
    ViewData["Title"] = "Success";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .success-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        gap: 1.5rem;
    }

    .success-icon {
        font-size: 4rem;
        line-height: 1;
    }

    .success-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

        .success-title span {
            color: #39d98a;
        }

    .success-sub {
        font-size: 0.95rem;
        color: #7a7a8c;
        max-width: 400px;
    }

    .divider {
        width: 60px;
        height: 2px;
        background: #ff2222;
    }

    .btn-back {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-block;
    }

        .btn-back:hover {
            background: #ff4444;
            color: #fff;
            transform: translateY(-2px);
        }
</style>

<div class="success-wrap">
    <div class="success-icon">✓</div>
    <div class="divider"></div>
    <h1 class="success-title">Product <span>Removed</span></h1>
    <p class="success-sub">The product has been successfully deleted from the store.</p>
    <a asp-action="Index" class="btn-back">← Back to Products</a>
</div>
