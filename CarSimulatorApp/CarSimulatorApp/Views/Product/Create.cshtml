@model CarSimulatorApp.Models.Product.ProductCreateVM
@{
    ViewData["Title"] = "Create Product";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .form-wrap {
        max-width: 680px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .form-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
    }

    .form-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

        .form-title span {
            color: #ff2222;
        }

    .form-subtitle {
        font-size: 0.85rem;
        color: #7a7a8c;
        margin-top: 0.4rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
        display: block;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background: #18181f !important;
        border: 1px solid #2e2e3a !important;
        color: #f0f0f5 !important;
        padding: 0.75rem 1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
        width: 100%;
        border-radius: 0 !important;
    }

        .form-control:focus {
            border-color: #ff2222 !important;
            box-shadow: none !important;
            background: #18181f !important;
            color: #f0f0f5 !important;
        }

        .form-control::placeholder {
            color: #7a7a8c;
        }

    select.form-control option {
        background: #18181f;
        color: #f0f0f5;
    }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .text-danger {
        font-size: 0.78rem;
        color: #ff4d6d !important;
        margin-top: 0.3rem;
        display: block;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .btn-save {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.85rem 2.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 0.5rem;
    }

        .btn-save:hover {
            background: #ff4444;
            transform: translateY(-2px);
        }

    .btn-back {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: transparent;
        color: #7a7a8c;
        border: 1px solid #2e2e3a;
        padding: 0.85rem 1.5rem;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-block;
        margin-top: 0.5rem;
        margin-left: 0.75rem;
    }

        .btn-back:hover {
            border-color: #ff2222;
            color: #ff2222;
        }

    @@media (max-width: 576px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="form-wrap">
    <div class="form-header">
        <h1 class="form-title">Create <span>Product</span></h1>
        <p class="form-subtitle">Add a new product to the store.</p>
    </div>

    <form asp-action="Create">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="ProductName"></label>
            <input class="form-control" asp-for="ProductName" placeholder="e.g. Racing Wheel Pro" />
            <span asp-validation-for="ProductName" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="BrandId"></label>
                <select class="form-control" asp-for="BrandId"
                        asp-items="@(new SelectList(Model.Brands, "Id", "Name"))">
                    <option value="">-- Select Brand --</option>
                </select>
                <span asp-validation-for="BrandId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="CategoryId"></label>
                <select class="form-control" asp-for="CategoryId"
                        asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Picture"></label>
            <input class="form-control" asp-for="Picture" placeholder="https://..." />
            <span asp-validation-for="Picture" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Description"></label>
            <textarea class="form-control" asp-for="Description" placeholder="Describe the product..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="Quantity"></label>
                <input class="form-control" asp-for="Quantity" type="number" min="0" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Price"></label>
                <input class="form-control" asp-for="Price" type="number" step="0.01" min="0" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Discount"></label>
            <input class="form-control" asp-for="Discount" type="number" step="0.01" min="0" max="100" placeholder="0 - 100" />
            <span asp-validation-for="Discount" class="text-danger"></span>
        </div>

        <div>
            <button type="submit" class="btn-save">Save Product</button>
            <a asp-action="Index" class="btn-back">← Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
