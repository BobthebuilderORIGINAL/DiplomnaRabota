@model CarSimulatorApp.Models.Product.ProductDetailsVM
@{
    ViewData["Title"] = "Details";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .details-wrap {
        max-width: 900px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .details-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .details-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

    .details-title span { color: #ff2222; }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
    }

    /* Left - Image */
    .details-img-wrap {
        width: 100%;
        aspect-ratio: 4/3;
        overflow: hidden;
        background: #18181f;
        border: 1px solid #2e2e3a;
        position: relative;
    }

    .details-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .stock-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        font-family: 'Syne', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 0.3rem 0.75rem;
    }

    .in-stock { background: #39d98a; color: #0f0f13; }
    .out-stock { background: #ff4d6d; color: #fff; }

    /* Right - Info */
    .details-info {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .details-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .tag {
        font-family: 'Syne', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 0.25rem 0.65rem;
        border: 1px solid #2e2e3a;
        color: #7a7a8c;
    }

    .tag.brand { border-color: rgba(255,34,34,0.4); color: #ff2222; }

    .details-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: #f0f0f5;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .details-price-row {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .price-original {
        font-size: 1rem;
        color: #7a7a8c;
        text-decoration: line-through;
    }

    .price-final {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: #e8ff47;
    }

    .price-discount {
        font-size: 0.85rem;
        color: #ff6b35;
        font-weight: 600;
    }

    .details-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .stat-box {
        background: #18181f;
        border: 1px solid #2e2e3a;
        padding: 0.75rem 1rem;
    }

    .stat-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
        display: block;
        margin-bottom: 0.25rem;
    }

    .stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: #f0f0f5;
    }

    /* Actions */
    .details-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .btn-action {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.75rem 1.5rem;
        text-decoration: none;
        border: 1px solid;
        transition: all 0.18s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .btn-order {
        background: #ff2222;
        border-color: #ff2222;
        color: #fff;
    }
    .btn-order:hover { background: #ff4444; color: #fff; border-color: #ff4444; }

    .btn-edit {
        background: transparent;
        border-color: #ffb830;
        color: #ffb830;
    }
    .btn-edit:hover { background: #ffb830; color: #0f0f13; }

    .btn-back {
        background: transparent;
        border-color: #2e2e3a;
        color: #7a7a8c;
    }
    .btn-back:hover { border-color: #ff2222; color: #ff2222; }

    @@media (max-width: 768px) {
        .details-grid { grid-template-columns: 1fr; }
        .details-header { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="details-wrap">
    <div class="details-header">
        <h1 class="details-title">Product <span>Details</span></h1>
        <a asp-action="Index" class="btn-action btn-back">← Back to Products</a>
    </div>

    <div class="details-grid">
        <!-- Image -->
        <div class="details-img-wrap">
            <img src="@Html.DisplayFor(model => model.Picture)" alt="@Model.ProductName" />
            @if (Model.Quantity > 0)
            {
                <span class="stock-badge in-stock">In Stock</span>
            }
            else
            {
                <span class="stock-badge out-stock">Out of Stock</span>
            }
        </div>

        <!-- Info -->
        <div class="details-info">
            <div class="details-tags">
                <span class="tag brand">@Html.DisplayFor(model => model.BrandName)</span>
                <span class="tag">@Html.DisplayFor(model => model.CategoryName)</span>
            </div>

            <h2 class="details-name">@Html.DisplayFor(model => model.ProductName)</h2>

            <div class="details-price-row">
                @if (Model.Discount > 0)
                {
                    decimal discounted = Model.Price - (Model.Price * Model.Discount / 100);
                    <span class="price-original">$@Model.Price.ToString("F2")</span>
                    <span class="price-final">$@discounted.ToString("F2")</span>
                    <span class="price-discount">-@Model.Discount%</span>
                }
                else
                {
                    <span class="price-final">$@Model.Price.ToString("F2")</span>
                }
            </div>

            <div class="details-stats">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="stat-box" style="grid-column: 1/-1;">
                        <span class="stat-label">Description</span>
                        <p style="color:#a0a0b0; font-size:0.9rem; margin:0; line-height:1.7;">@Model.Description</p>
                    </div>
                }
                <div class="stat-box">
                    <span class="stat-label">Quantity</span>
                    <span class="stat-value">@Html.DisplayFor(model => model.Quantity)</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Discount</span>
                    <span class="stat-value">@Html.DisplayFor(model => model.Discount)%</span>
                </div>

                <!-- ADD THIS -->
                <div class="stat-box" style="grid-column: 1/-1;">
                    <span class="stat-label">Rating</span>
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
                        @await Html.PartialAsync("_Stars", Model.AverageRating)
                        <span style="color:#7a7a8c; font-size:0.8rem;">
                            @if (Model.RatingCount > 0)
                            {
                                <text>@Model.AverageRating.ToString("F1") out of 5 (@Model.RatingCount reviews)</text>
                            }
                            else
                            {
                                <text>No ratings yet</text>
                            }
                        </span>
                    </div>
                    @if (User.Identity.IsAuthenticated && Model.HasOrdered)
                    {
                        <form asp-controller="Rating" asp-action="Rate" method="post" style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <span style="color:#7a7a8c; font-size:0.75rem; font-family:'Syne',sans-serif; text-transform:uppercase; letter-spacing:0.1em;">
                                @(Model.UserRating.HasValue ? "Your rating:" : "Rate this product:")
                            </span>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="submit" name="stars" value="@i"
                                        style="background:transparent; border:none; font-size:1.4rem; cursor:pointer; color:@(Model.UserRating.HasValue && i <= Model.UserRating.Value ? "#ffb830" : "#3a3a4a"); padding:0 2px;"
                                        onmouseover="hoverStars(this, @i)"
                                        onmouseout="resetStars(@(Model.UserRating ?? 0))">
                                    ★
                                </button>
                            }
                            @if (Model.UserRating.HasValue)
                            {
                                <span style="color:#7a7a8c; font-size:0.75rem;">(@Model.UserRating.Value/5)</span>
                            }
                        </form>
                    }
                    else if (User.Identity.IsAuthenticated && !Model.HasOrdered)
                    {
                        <span style="color:#7a7a8c; font-size:0.78rem; font-style:italic;">Order this product to leave a rating.</span>
                    }
                </div>

            </div> <!-- end details-stats -->

            <div class="details-actions">
                @if (this.User.Identity.IsAuthenticated && Model.Quantity > 0)
                {
                    <a asp-action="Create" asp-controller="Order" asp-route-id="@Model.Id" class="btn-action btn-order">Order Now</a>
                }
                @if ((this.User.Identity.IsAuthenticated) && (this.User.IsInRole("Administrator")))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action btn-edit">Edit</a>
                }
            </div>
        </div>
    </div>
</div>
<script>
    function hoverStars(el, count) {
        const stars = el.parentElement.querySelectorAll('button[name="stars"]');
        stars.forEach((s, i) => s.style.color = i < count ? '#ffb830' : '#3a3a4a');
    }
    function resetStars(userRating) {
        const stars = document.querySelectorAll('button[name="stars"]');
        stars.forEach((s, i) => s.style.color = i < userRating ? '#ffb830' : '#3a3a4a');
    }
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
