
@model List<CarSimulatorApp.Infrastructure.Data.Domain.Favourites>

    @{
        ViewData["Title"] = "My Favourites";
    }

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 style="font-weight:800;">My <span style="color:#e63946;">Favourites</span></h2>
            <span style="color:gray; font-size:0.85rem; letter-spacing:1px;">@Model.Count FAVOURITE@(Model.Count != 1 ? "S" : "")</span>
        </div>
        <hr style="border-color:#e63946;" />

        @if  (!((List<CarSimulatorApp.Infrastructure.Data.Domain.Favourites>)Model).Any())
        {
            <p style="color:gray;">You have no favourites yet.</p>
        }
        else
        {
            @foreach (var fav in Model)
            {
                <div class="card mb-3" style="background:#1a1a1a; border:1px solid #2a2a2a; border-radius:8px; max-width:600px;">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <img src="@fav.Product.Picture" alt="@fav.Product.ProductName"
                                 style="width:120px; height:90px; object-fit:cover; border-radius:6px;" />
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 style="color:white; font-weight:700; margin-bottom:4px;">
                                        ❤️ @fav.Product.ProductName
                                    </h5>
                                </div>
                                <small style="color:#4a90d9;">🕐 @fav.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</small>
                                <div class="mt-2 d-flex gap-3">
                                    <div style="background:#111; padding:6px 14px; border-radius:4px; text-align:center;">
                                        <div style="color:gray; font-size:0.7rem; letter-spacing:1px;">PRICE</div>
                                        <div style="color:white; font-weight:600;">$@fav.Product.Price.ToString("F2")</div>
                                    </div>
                                    <div style="background:#111; padding:6px 14px; border-radius:4px; text-align:center;">
                                        <div style="color:gray; font-size:0.7rem; letter-spacing:1px;">DISCOUNT</div>
                                        <div style="color:white; font-weight:600;">@fav.Product.Discount.ToString("F2")%</div>
                                    </div>
                                </div>
                            </div>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="id" value="@fav.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:transparent; border:none; color:#e63946; font-size:1.3rem;" title="Remove">✕</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
