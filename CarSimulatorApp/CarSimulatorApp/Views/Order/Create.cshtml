@model CarSimulatorApp.Models.Order.OrderCreateVM
@{
    ViewData["Title"] = "Order";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body, main, .container {
        background: #0f0f13 !important;
        color: #f0f0f5;
        font-family: 'DM Sans', sans-serif;
    }

    .order-wrap {
        max-width: 860px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .order-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #ff2222;
    }

    .order-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #f0f0f5;
        margin: 0;
    }

        .order-title span {
            color: #ff2222;
        }

    .order-subtitle {
        font-size: 0.85rem;
        color: #7a7a8c;
        margin-top: 0.4rem;
    }

    .order-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
        align-items: start;
    }

    /* Left - Product Preview */
    .product-preview {
        background: #18181f;
        border: 1px solid #2e2e3a;
        overflow: hidden;
    }

    .preview-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }

    .preview-body {
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .preview-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: #f0f0f5;
        margin: 0;
    }

    .preview-price-row {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
    }

    .preview-price {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: #e8ff47;
    }

    .preview-original {
        font-size: 0.9rem;
        color: #7a7a8c;
        text-decoration: line-through;
    }

    .preview-discount {
        font-size: 0.8rem;
        color: #ff6b35;
        font-weight: 600;
    }

    .preview-stat {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        border-top: 1px solid #2e2e3a;
    }

    .preview-stat-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
    }

    .preview-stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        color: #f0f0f5;
    }

    /* Right - Order Form */
    .order-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
    }

    .form-control {
        background: #18181f !important;
        border: 1px solid #2e2e3a !important;
        color: #f0f0f5 !important;
        padding: 0.75rem 1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
        width: 100%;
        border-radius: 0 !important;
    }

        .form-control:focus {
            border-color: #ff2222 !important;
            box-shadow: none !important;
        }

        .form-control[readonly] {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .qty-hint {
        font-size: 0.75rem;
        color: #7a7a8c;
    }

        .qty-hint span {
            color: #39d98a;
            font-weight: 600;
        }

    .total-box {
        background: #18181f;
        border: 1px solid #ff2222;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .total-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7a7a8c;
    }

    .total-value {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: #ff2222;
    }

    .text-danger {
        font-size: 0.78rem;
        color: #ff4d6d !important;
    }

    .form-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-order {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: #ff2222;
        color: #fff;
        border: none;
        padding: 0.85rem 2.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-order:hover {
            background: #ff4444;
            transform: translateY(-2px);
        }

    .btn-back {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: transparent;
        color: #7a7a8c;
        border: 1px solid #2e2e3a;
        padding: 0.85rem 1.5rem;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

        .btn-back:hover {
            border-color: #ff2222;
            color: #ff2222;
        }

    @@media (max-width: 768px) {
        .order-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="order-wrap">
    <div class="order-header">
        <h1 class="order-title">Place <span>Order</span></h1>
        <p class="order-subtitle">Review your product and confirm your order.</p>
    </div>

    <div class="order-grid">
        <!-- Left: Product Preview -->
        <div class="product-preview">
            <img src="@Model.Picture" class="preview-img" alt="@Model.ProductName" />
            <div class="preview-body">
                <h3 class="preview-name">@Model.ProductName</h3>
                <div class="preview-price-row">
                    @if (Model.Discount > 0)
                    {
                        decimal discounted = Model.Price - (Model.Price * Model.Discount / 100);
                        <span class="preview-original">$@Model.Price.ToString("F2")</span>
                        <span class="preview-price">$@discounted.ToString("F2")</span>
                        <span class="preview-discount">-@Model.Discount%</span>
                    }
                    else
                    {
                        <span class="preview-price">$@Model.Price.ToString("F2")</span>
                    }
                </div>
                <div class="preview-stat">
                    <span class="preview-stat-label">Available Stock</span>
                    <span class="preview-stat-value">@Model.QuantityInStock units</span>
                </div>
                <div class="preview-stat">
                    <span class="preview-stat-label">Discount</span>
                    <span class="preview-stat-value">@Model.Discount%</span>
                </div>
            </div>
        </div>

        <!-- Right: Order Form -->
        <form asp-action="Create" class="order-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="Picture" />
            <input type="hidden" asp-for="ProductName" />
            <input type="hidden" asp-for="Price" />
            <input type="hidden" asp-for="Discount" />

            <div class="form-group">
                <label class="form-label">Quantity</label>
                <input asp-for="Quantity" class="form-control" type="number"
                       min="1" max="@Model.QuantityInStock"
                       oninput="calcSum()" />
                <span class="qty-hint">Max available: <span>@Model.QuantityInStock</span></span>
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="total-box">
                <span class="total-label">Total Price</span>
                <span class="total-value" id="totalDisplay">$0.00</span>
                <input type="hidden" asp-for="TotalPrice" id="TotalPrice" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-order">Confirm Order →</button>
                <a asp-action="Index" asp-controller="Product" class="btn-back">← Back</a>
            </div>
        </form>
    </div>
</div>

<script>
    function calcSum() {
        let q = document.getElementsByName('Quantity')[0].value;
        let p = @Model.Price;
        let d = @Model.Discount;
        let sum = Number(q) * (Number(p) - Number(p) * Number(d) / 100);
        document.getElementById('TotalPrice').value = sum.toFixed(2);
        document.getElementById('totalDisplay').textContent = '$' + sum.toFixed(2);
    }

    document.getElementById('Quantity').max = @Model.QuantityInStock;
    document.getElementById('Quantity').min = 1;

    // Init total on load
    calcSum();
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

